[Desktop Entry]
Name=Nexon Game Manager
Exec=env WINEPREFIX=%HOME%/.wine-msworlds WINEDEBUG=-all DISPLAY=:0 XMODIFIERS=@im=fcitx GTK_IM_MODULE=fcitx QT_IM_MODULE=fcitx SDL_IM_MODULE=fcitx INPUT_METHOD=fcitx WINEFSYNC=1 WINEESYNC=1 STAGING_SHARED_MEMORY=1 DXVK_ASYNC=1 DXVK_CONFIG_FILE=%HOME%/.wine-msworlds/drive_c/dxvk.conf mesa_glthread=true MESA_NO_ERROR=1 RADV_DEBUG=nozerovram AMD_VULKAN_ICD=RADV %HOME%/.local/share/wine-runners/wine-10.6-staging-tkg-amd64-wow64/bin/wine "%HOME%/.wine-msworlds/drive_c/ProgramData/Nexon/NGM/NGM64.exe" "%u"
Type=Application
MimeType=x-scheme-handler/ngm;
NoDisplay=true
StartupNotify=false
